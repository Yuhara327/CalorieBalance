    "摂取量が消費量を上回っています。このペースが維持されれば、体重の増加が見込まれます。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Aufnahme übersteigt den Verbrauch. Bei diesem Tempo ist mit einer Gewichtszunahme zu rechnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calorie intake exceeds expenditure. Weight gain is expected if this pace is maintained."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calorie intake exceeds expenditure. Expect weight gain if this pace continues."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ingesta supera el gasto. Si se mantiene este ritmo, se espera un aumento de peso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'apport dépasse la dépense. Si ce rythme se maintient, une prise de poids est à prévoir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "摂取量が消費量を上回っています。このペースが維持されれば、体重の増加が見込まれます。"
          }
        },
